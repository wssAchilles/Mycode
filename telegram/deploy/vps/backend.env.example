NODE_ENV=production
PORT=5000

# Container image tags are injected by deploy/vps/release_backend.sh via deploy/vps/.env.
# Do not put BACKEND_IMAGE / GATEWAY_IMAGE / RELEASE_TAG in this runtime env file.

# External managed databases
MONGODB_URI=
DATABASE_URL=

# Local Redis in compose
REDIS_URL=redis://redis:6379
REDIS_ENABLED=true

# Auth / AI
JWT_SECRET=
GEMINI_API_KEY=

# Files / sockets / ops
AI_SOCKET_ENABLED=false
OPS_METRICS_TOKEN=change-me
FRONTEND_ORIGIN=https://telegram-467705.web.app
FRONTEND_ORIGINS=
CORS_EXTRA_ORIGINS=

# Optional tuning
NODE_OPTIONS=--dns-result-order=ipv4first --max-old-space-size=768
SOCKET_BATCH_PROFILE=prod
CHAT_MESSAGE_WORKER_CONCURRENCY=5
NOTIFICATION_WORKER_CONCURRENCY=10
FANOUT_WORKER_CONCURRENCY=2
FANOUT_JOB_RECIPIENTS_MAX=800
FANOUT_MEMBERSTATE_CHUNK_SIZE=500
FANOUT_FALLBACK_CHUNK_SIZE=500
SYNC_APPEND_UPDATES_CHUNK_SIZE=100

# Rust ingress gateway (Phase 2)
GATEWAY_BIND_ADDR=0.0.0.0:4000
GATEWAY_UPSTREAM_HTTP=http://backend:5000
GATEWAY_VALIDATE_ACCESS_TOKENS=true
GATEWAY_TRUST_X_FORWARDED_FOR=true
GATEWAY_RATE_LIMIT_CAPACITY=120
GATEWAY_RATE_LIMIT_REFILL_PER_SEC=2
GATEWAY_REQUEST_TIMEOUT_SECS=30
