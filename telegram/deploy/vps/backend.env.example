NODE_ENV=production
PORT=5000

# Container image tags are injected by deploy/vps/release_backend.sh via deploy/vps/.env.
# Do not put BACKEND_IMAGE / GATEWAY_IMAGE / RELEASE_TAG in this runtime env file.

# External managed databases
MONGODB_URI=
DATABASE_URL=

# Local Redis in compose
REDIS_URL=redis://redis:6379
REDIS_ENABLED=true

# Auth / AI
JWT_SECRET=
GEMINI_API_KEY=

# Files / sockets / ops
AI_SOCKET_ENABLED=false
OPS_METRICS_TOKEN=change-me
FRONTEND_ORIGIN=https://telegram-467705.web.app
FRONTEND_ORIGINS=
CORS_EXTRA_ORIGINS=

# Optional tuning
NODE_OPTIONS=--dns-result-order=ipv4first --max-old-space-size=768
SOCKET_BATCH_PROFILE=prod
CHAT_MESSAGE_WORKER_CONCURRENCY=5
NOTIFICATION_WORKER_CONCURRENCY=10
FANOUT_WORKER_CONCURRENCY=2
FANOUT_JOB_RECIPIENTS_MAX=800
FANOUT_MEMBERSTATE_CHUNK_SIZE=500
FANOUT_FALLBACK_CHUNK_SIZE=500
SYNC_APPEND_UPDATES_CHUNK_SIZE=100
SYNC_WAKE_EXECUTION_MODE=platform_bus
NOTIFICATION_DISPATCH_EXECUTION_MODE=direct_queue
DELIVERY_EXECUTION_MODE=go_primary
DELIVERY_CONSUMER_SUMMARY_URL=http://delivery_consumer:4100/ops/summary
RUST_RECOMMENDATION_MODE=shadow
RUST_RECOMMENDATION_URL=http://recommendation:4200
RUST_RECOMMENDATION_SUMMARY_URL=http://recommendation:4200/ops/recommendation/summary
RECOMMENDATION_INTERNAL_TOKEN=change-me
GRAPH_KERNEL_INTERNAL_TOKEN=change-me
CPP_GRAPH_KERNEL_ENABLED=true
CPP_GRAPH_KERNEL_URL=http://graph_kernel:4300
CPP_GRAPH_KERNEL_SUMMARY_URL=http://graph_kernel:4300/ops/graph
CPP_GRAPH_KERNEL_TIMEOUT_MS=1200

# Rust ingress gateway (Phase 2)
GATEWAY_BIND_ADDR=0.0.0.0:4000
GATEWAY_UPSTREAM_HTTP=http://backend:5000
GATEWAY_VALIDATE_ACCESS_TOKENS=true
GATEWAY_TRUST_X_FORWARDED_FOR=true
GATEWAY_RATE_LIMIT_CAPACITY=120
GATEWAY_RATE_LIMIT_REFILL_PER_SEC=2
GATEWAY_REQUEST_TIMEOUT_SECS=30
GATEWAY_SYNC_REQUEST_TIMEOUT_SECS=45

# Rust realtime boundary (Phase 14 compat_primary baseline)
GATEWAY_REALTIME_REDIS_URL=redis://redis:6379/0
GATEWAY_REALTIME_STREAM_KEY=realtime:ingress:v1
GATEWAY_REALTIME_DLQ_STREAM_KEY=realtime:dlq:v1
GATEWAY_REALTIME_CONSUMER_GROUP=gateway-realtime-boundary
GATEWAY_REALTIME_CONSUMER_NAME=
GATEWAY_REALTIME_ROLLOUT_STAGE=compat_primary
GATEWAY_REALTIME_HEARTBEAT_STALE_SECS=120

# Rust recommendation retrieval/ranking pipeline (Phase 21 graph-orchestrated baseline)
RUST_RECOMMENDATION_BIND_ADDR=0.0.0.0:4200
RUST_RECOMMENDATION_BACKEND_URL=http://backend:5000/internal/recommendation
RUST_RECOMMENDATION_TIMEOUT_MS=3500
RUST_RECOMMENDATION_STAGE=retrieval_ranking_v2
RUST_RECOMMENDATION_RETRIEVAL_MODE=source_orchestrated_graph_v1
RUST_RECOMMENDATION_RANKING_MODE=phoenix_standardized
RUST_RECOMMENDATION_SOURCE_ORDER=FollowingSource,GraphSource,NewsAnnSource,PopularSource,TwoTowerSource,ColdStartSource
RUST_RECOMMENDATION_GRAPH_SOURCE_ENABLED=true
RUST_RECOMMENDATION_SELECTOR_OVERSAMPLE_FACTOR=5
RUST_RECOMMENDATION_SELECTOR_MAX_SIZE=200
RUST_RECOMMENDATION_RECENT_PER_USER_CAPACITY=64
RUST_RECOMMENDATION_RECENT_GLOBAL_CAPACITY=256
RUST_RECOMMENDATION_RECENT_SOURCE_ENABLED=true

# C++ graph kernel (Phase 20 read-only snapshot graph)
GRAPH_KERNEL_BIND_ADDR=0.0.0.0:4300
GRAPH_KERNEL_BACKEND_SNAPSHOT_URL=http://backend:5000/internal/graph-kernel/snapshot
GRAPH_KERNEL_BACKEND_TIMEOUT_MS=4000
GRAPH_KERNEL_SNAPSHOT_REFRESH_SECS=300
GRAPH_KERNEL_SNAPSHOT_PAGE_SIZE=1000
GRAPH_KERNEL_MIN_EDGE_SCORE=0.05
GRAPH_KERNEL_MAX_NEIGHBORS_PER_USER=128
GRAPH_KERNEL_MAX_BRANCHING_FACTOR=32
GRAPH_KERNEL_DEFAULT_NEIGHBOR_LIMIT=40
GRAPH_KERNEL_DEFAULT_AUTHOR_LIMIT=40
GRAPH_KERNEL_DEFAULT_OVERLAP_LIMIT=20
GRAPH_KERNEL_DEFAULT_MAX_DEPTH=2

# Go delivery consumer (Phase 15 full primary + platform bus baseline)
DELIVERY_CONSUMER_BIND_ADDR=0.0.0.0:4100
DELIVERY_CONSUMER_REDIS_URL=
DELIVERY_CONSUMER_STREAM_KEY=chat:delivery:bus:v1
DELIVERY_CONSUMER_PLATFORM_STREAM_KEY=platform:events:v1
DELIVERY_CONSUMER_GROUP=go-delivery-primary
DELIVERY_CONSUMER_CONSUMER_NAME=
DELIVERY_CONSUMER_BLOCK_MS=2000
DELIVERY_CONSUMER_READ_COUNT=20
DELIVERY_CONSUMER_DRY_RUN=false
DELIVERY_CONSUMER_EXECUTION_MODE=primary
DELIVERY_CONSUMER_DLQ_STREAM_KEY=chat:delivery:bus:dlq:v1
DELIVERY_CONSUMER_PLATFORM_DLQ_STREAM_KEY=platform:events:dlq:v1
DELIVERY_CONSUMER_CANARY_STREAM_KEY=chat:delivery:canary:v1
DELIVERY_CONSUMER_MAX_RECIPIENTS_PER_CHUNK=800
DELIVERY_CANARY_SEGMENT=projection_bookkeeping
DELIVERY_CANARY_MISMATCH_THRESHOLD=5
DELIVERY_CANARY_DLQ_THRESHOLD=3
DELIVERY_CONSUMER_CANARY_MISMATCH_THRESHOLD=5
DELIVERY_CONSUMER_CANARY_DLQ_THRESHOLD=3

# Phase 13 full primary rollout. Private + selected-size groups run on Go, Node stays fallback/replay-only.
DELIVERY_GO_PRIMARY_READY=true
DELIVERY_GO_PRIMARY_PRIVATE_ENABLED=true
DELIVERY_GO_PRIMARY_GROUP_ENABLED=true
DELIVERY_GO_PRIMARY_PRIVATE_ROLLOUT_PERCENT=100
DELIVERY_GO_PRIMARY_GROUP_ROLLOUT_PERCENT=100
DELIVERY_GO_PRIMARY_MAX_RECIPIENTS=2
DELIVERY_GO_PRIMARY_GROUP_MAX_RECIPIENTS=32
DELIVERY_GO_PRIMARY_ALLOW_CHAT_IDS=
DELIVERY_GO_PRIMARY_ALLOW_SENDER_IDS=
DELIVERY_GO_PRIMARY_GROUP_ALLOW_CHAT_IDS=
DELIVERY_GO_PRIMARY_GROUP_ALLOW_SENDER_IDS=
DELIVERY_CONSUMER_PRIMARY_MAX_RECIPIENTS=2
DELIVERY_CONSUMER_PRIMARY_GROUP_MAX_RECIPIENTS=32
DELIVERY_CONSUMER_PRIMARY_MAX_ATTEMPTS=3
DELIVERY_CONSUMER_PRIMARY_PRIVATE_ROLLOUT_PERCENT=100
DELIVERY_CONSUMER_PRIMARY_GROUP_ROLLOUT_PERCENT=100
DELIVERY_CONSUMER_PROJECTION_CHUNK_SIZE=500
DELIVERY_CONSUMER_MONGO_URL=
DELIVERY_CONSUMER_MONGO_DATABASE=
DELIVERY_CONSUMER_MEMBER_STATE_COLLECTION=chatmemberstates
DELIVERY_CONSUMER_UPDATE_COUNTER_COLLECTION=updatecounters
DELIVERY_CONSUMER_UPDATE_LOG_COLLECTION=updatelogs
DELIVERY_CONSUMER_OUTBOX_COLLECTION=chatdeliveryoutboxes
DELIVERY_CONSUMER_WAKE_PUBSUB_CHANNEL=sync:update:wake:v1
DELIVERY_CONSUMER_SYNC_WAKE_EXECUTION_MODE=publish
DELIVERY_CONSUMER_PRESENCE_EXECUTION_MODE=shadow
DELIVERY_CONSUMER_NOTIFICATION_EXECUTION_MODE=shadow
DELIVERY_CONSUMER_PRESENCE_ONLINE_CHANNEL=user:online
DELIVERY_CONSUMER_PRESENCE_OFFLINE_CHANNEL=user:offline
DELIVERY_CONSUMER_NOTIFICATION_CHANNEL=notification
