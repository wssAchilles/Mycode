FROM rust:1.93-bookworm AS builder
WORKDIR /app

COPY Cargo.toml Cargo.lock ./
COPY src ./src

RUN cargo build --release

FROM debian:bookworm-slim
RUN apt-get update \
  && apt-get install -y --no-install-recommends ca-certificates \
  && rm -rf /var/lib/apt/lists/*

COPY --from=builder /app/target/release/telegram-rust-gateway /usr/local/bin/telegram-rust-gateway

EXPOSE 4000
ENTRYPOINT ["/usr/local/bin/telegram-rust-gateway"]
